{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "pnpm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "timeout": 60
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "dist/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "dist/public/index.html",
      "status": 200
    }
  ]
}
